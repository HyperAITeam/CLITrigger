{
  "name": "clitrigger",
  "version": "0.2.11",
  "description": "Spawn isolated git worktrees and orchestrate Claude/Gemini/Codex CLI tasks in parallel from a web UI.",
  "keywords": [
    "claude",
    "gemini",
    "codex",
    "cli",
    "ai",
    "orchestration",
    "worktree",
    "automation",
    "electron",
    "tunnel"
  ],
  "homepage": "https://github.com/HyperAITeam/CLITrigger#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HyperAITeam/CLITrigger.git"
  },
  "bugs": {
    "url": "https://github.com/HyperAITeam/CLITrigger/issues"
  },
  "author": "HyperAI Team",
  "license": "MIT",
  "type": "module",
  "main": "electron/main.cjs",
  "bin": {
    "clitrigger": "bin/clitrigger.js"
  },
  "files": [
    "dist/",
    "bin/",
    "electron/",
    ".env.example",
    "README_KR.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "cd src/client && npx vite",
    "build": "npm run build:client && npm run build:server && node -e \"const fs=require('fs');fs.cpSync('src/client/dist','dist/client',{recursive:true})\"",
    "prepublishOnly": "cd src/client && npm ci && cd ../.. && npm run build",
    "build:server": "tsc -p tsconfig.server.json && node -e \"const fs=require('fs');fs.cpSync('src/server/resources','dist/server/resources',{recursive:true});fs.cpSync('src/server/data','dist/server/data',{recursive:true})\"",
    "build:client": "cd src/client && npx vite build",
    "start": "node dist/server/index.js",
    "start:tunnel": "npm run build && node -e \"process.env.TUNNEL_ENABLED='true'; import('./dist/server/index.js')\"",
    "test": "npm run test:server && npm run test:client",
    "test:server": "vitest run --config vitest.config.ts",
    "test:client": "cd src/client && npx vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage && cd src/client && npx vitest run --config vitest.config.ts --coverage",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && cd src/client && npx tsc --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "typecheck:client": "cd src/client && npx tsc --noEmit",
    "build:plugin": "npm run build && npx esbuild dist/server/index.js --bundle --platform=node --format=esm --outfile=plugin-build/server/server.js --external:better-sqlite3 --external:node-pty",
    "docs:erd": "tsx scripts/generate-erd.ts",
    "docs:erd:check": "tsx scripts/generate-erd.ts --check",
    "postuninstall": "node bin/postuninstall.js",
    "electron:rebuild": "electron-rebuild -o better-sqlite3 --force --build-from-source",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@types/iarna__toml": "^2.0.5",
    "better-sqlite3": "^11.7.0",
    "cloudflared": "^0.7.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "electron-updater": "^6.8.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "node-cron": "^4.2.1",
    "node-pty": "^1.1.0",
    "simple-git": "^3.27.0",
    "tree-kill": "^1.2.2",
    "uuid": "^11.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.1",
    "@types/helmet": "^0.0.48",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^4.1.1",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.27.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1"
  },
  "build": {
    "appId": "com.clitrigger.app",
    "productName": "CLITrigger",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "HyperAITeam",
        "repo": "CLITrigger",
        "releaseType": "release"
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "bin/**/*",
      "package.json",
      "!**/*.map",
      "!**/*.ts",
      "!**/__tests__/**",
      "!**/*.test.*"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/node-pty/**",
      "node_modules/cloudflared/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "category": "Development",
      "target": [
        "AppImage"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "appx": {
      "applicationId": "CLITrigger",
      "identityName": "com.clitrigger.app",
      "publisher": "CN=CLITrigger Dev",
      "publisherDisplayName": "CLITrigger"
    }
  }
}
